<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECURITY DASHBOARD"
            android:textSize="14sp"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM BEHAVIOR"
            android:textSize="12sp"
            android:textColor="#555555" />

        <TextView
            android:id="@+id/sysScoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="32dp" />

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NETWORK TRAFFIC"
            android:textSize="12sp"
            android:textColor="#555555" />

        <TextView
            android:id="@+id/netScoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ENABLE PROTECTION"
            android:backgroundTint="#000000"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnConnectServer"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CENTRAL INTELLIGENCE"
            android:textColor="#888888"
            android:textSize="10sp"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Secure"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/threatInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F9F9F9"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/detectedAppNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Application ID"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/anomalyTypeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Observation"
                android:textSize="12sp"
                android:textColor="#D32F2F"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/hashLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHA-256 SIGNATURE:"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/hashValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="signature_value"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textColor="#555555"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnKill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACTION: TERMINATE"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>